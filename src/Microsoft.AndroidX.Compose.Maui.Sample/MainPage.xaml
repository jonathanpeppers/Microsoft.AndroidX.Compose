<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Microsoft.AndroidX.Compose.Maui.Sample.MainPage"
             Title="AndroidX.Compose backend">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label
                Text="Hello, World!"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Welcome to &#10;.NET MAUI on Jetpack Compose"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net MAUI on Jetpack Compose" />

            <Entry
                x:Name="NameEntry"
                Placeholder="Type your name"
                TextChanged="OnNameTextChanged"
                HorizontalOptions="Fill" />

            <Label
                x:Name="GreetingLabel"
                Text="Greeting will appear here."
                HorizontalOptions="Fill" />

            <Entry
                x:Name="SecretEntry"
                Placeholder="Password (masked)"
                IsPassword="True"
                HorizontalOptions="Fill" />

            <Entry
                x:Name="DigitsEntry"
                Placeholder="Numeric IME"
                Keyboard="Numeric"
                HorizontalOptions="Fill" />

            <!-- Exercises MapTextColor + MapFont (size + bold) on the
                 input — analogue of the gallery's TextStyleOverrideDemo. -->
            <Entry
                x:Name="StyledEntry"
                Text="Big bold blue"
                TextColor="#2196F3"
                FontSize="22"
                FontAttributes="Bold"
                HorizontalOptions="Fill" />

            <!-- Exercises MapIsReadOnly — focus + selection still work,
                 keyboard suppressed. -->
            <Entry
                x:Name="ReadOnlyEntry"
                Text="Read-only (no keyboard)"
                IsReadOnly="True"
                HorizontalOptions="Fill" />

            <Button
                x:Name="CounterBtn"
                Text="Click me"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill" />

            <!-- Exercises ContentScale.Crop on the same image source
                 to prove the Aspect mapper differentiates from the
                 AspectFit case above. Cropped to a strip so the
                 visual difference is obvious. -->
            <Image
                Source="dotnet_bot.png"
                HeightRequest="80"
                Aspect="AspectFill"
                SemanticProperties.Description="cropped dot net bot strip" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
