<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Microsoft.AndroidX.Compose.Maui.Sample.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Microsoft.AndroidX.Compose.Maui.Sample"
    Title="Compose Gallery"
    FlyoutBehavior="Disabled">

    <!--
        Single-content Shell. The home page is `HomePage`, a list of
        demos; each row routes to a registered detail page via
        `Shell.GoToAsync(...)` (routes registered in `AppShell.xaml.cs`).
        FlyoutBehavior=Disabled hides the default hamburger / drawer —
        the gallery navigates exclusively via the home list, with the
        Shell back button on each detail page.
    -->
    <ShellContent
        Title="Compose Gallery"
        ContentTemplate="{DataTemplate local:HomePage}"
        Route="home" />

</Shell>
