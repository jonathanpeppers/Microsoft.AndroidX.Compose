root = true

[*.cs]
# IDE0001: Simplify name (e.g. System.Action -> Action when System is implicit)
dotnet_diagnostic.IDE0001.severity = error
# IDE0005: Remove unnecessary using directives
dotnet_diagnostic.IDE0005.severity = error

# Generated files under obj/ (Xamarin.Android namespace mappings, resource
# designer, etc.) lack an <auto-generated> header so analyzers treat them
# as user code by default. Mark them as generated.
[**/obj/**/*.cs]
generated_code = true
